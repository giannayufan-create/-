rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Core helpers
    function isSignedIn() { return request.auth != null; }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdminEmail() {
      return request.auth != null && request.auth.token.email in ['giannayufan@gmail.com', 'ko520940@gmail.com'];
    }
    function isAdmin() {
      return isAdminEmail() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // users/{userId}
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // products/{productId}
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // orders/{orderId}
    match /orders/{orderId} {
      allow read, write: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || !exists(/databases/$(database)/documents/orders/$(orderId)));
    }

    // settings/{settingId}
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
